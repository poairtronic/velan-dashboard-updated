# Velan Metrology Dashboard Configuration Example

# Frontend Configuration
VITE_API_BASE= # Base URL of the backend (e.g., http://localhost:10000 or empty for relative same-host serving)

# Backend Server Configuration
PORT=10000
ALLOWED_ORIGIN= # Authorized client origin for CORS restrictions (leave empty for development)
CACHE_TTL=60 # Google Sheets cache time-to-live in seconds

# Database Configuration
DATABASE_URL= # Neon PostgreSQL Connection String (set to 'mock' for local in-memory testing)

# JWT Security Secrets (Use long, randomly generated strings)
JWT_SECRET= # Secret for access token JWT signing
JWT_REFRESH_SECRET= # Secret for refresh token JWT signing

# Legacy API Fallback Credentials
ADMIN_USER=admin
ADMIN_PASS=admin123
USER_USER=user
USER_PASS=user123

# Dangerous API Execution Token
API_SECRET= # Token required for integrations to upload/wipe data (passed in x-api-key header)

# Data Sourcing Configurations
LIVE_URL= # Google Sheets URL published as CSV for live operational data
HISTORY_URL= # Google Sheets URL published as CSV for backup/wiping restores
