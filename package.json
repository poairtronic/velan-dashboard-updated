    "@tanstack/react-query": "^5.101.0",
    "@upstash/redis": "^1.38.0",
    "@vitejs/plugin-react": "^4.2.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "chart.js": "^4.4.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.5.28",
    "lodash": "^4.18.1",
    "logrocket": "^12.1.1",
    "lucide-react": "^1.20.0",
    "morgan": "^1.11.0",
    "pg": "^8.11.3",
