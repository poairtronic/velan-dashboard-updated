    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.1.2",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.17.0",
    "react-window": "^1.8.10",
