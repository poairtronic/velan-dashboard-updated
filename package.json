{
  "name": "velan-metrology-dashboard",
  "version": "2.0.0",
  "description": "Velan Metrology Production Command Center — Neon PostgreSQL + Google Sheets + React",
  "main": "server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node src/server/server.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,html}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "dashboard",
    "production",
    "metrology"
  ],
  "author": "Velan Metrology",
  "license": "ISC",
  "dependencies": {
